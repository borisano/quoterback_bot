# Telegram bot token.
# Local development: use your DEV bot token (@quoterback_dev_bot). Never the prod token.
# Production: set via Kamal secrets (.kamal/secrets), NOT here.
TELEGRAM_BOT_TOKEN=your-dev-bot-token-here

# Telegram webhook secret token (production only).
# Set a random secret here; pass the same value to setWebhook.
# If unset, the webhook controller skips secret verification (fine for dev/test).
TELEGRAM_WEBHOOK_SECRET=

# Admin dashboard credentials (HTTP Basic Auth).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Error tracking
ROLLBAR_ACCESS_TOKEN=your-rollbar-token-here
